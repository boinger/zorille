#!/usr/bin/env bash
set -euo pipefail

SKILL_DIR="$HOME/.claude/skills/codebase-audit"
SOURCE_DIR="$(cd "$(dirname "$0")" && pwd)"

# Upgrade mode: if already installed and pointing here, just pull
if [ -L "$SKILL_DIR" ] && [ "$(readlink "$SKILL_DIR")" = "$SOURCE_DIR" ]; then
  echo "Already installed. Pulling latest..."
  git -C "$SOURCE_DIR" pull 2>/dev/null || true
  echo "Updated to v$(cat "$SOURCE_DIR/VERSION")"
  exit 0
fi

# Warn if symlink points to a different source
if [ -L "$SKILL_DIR" ]; then
  echo "WARNING: $SKILL_DIR currently points to $(readlink "$SKILL_DIR")"
  echo "Replacing with $SOURCE_DIR"
fi

# Safety: don't overwrite a real directory
if [ -d "$SKILL_DIR" ] && [ ! -L "$SKILL_DIR" ]; then
  echo "ERROR: $SKILL_DIR exists and is a real directory (not a symlink)."
  echo "Remove it first if you want to install: rm -rf $SKILL_DIR"
  exit 1
fi

# Create parent dir if needed
mkdir -p "$(dirname "$SKILL_DIR")"

# Create symlink
ln -sf "$SOURCE_DIR" "$SKILL_DIR"

echo "Installed /codebase-audit v$(cat "$SOURCE_DIR/VERSION")"
echo ""
echo "Audit reports will be saved to ~/.codebase-audits/ on first run."
echo "Set CODEBASE_AUDIT_HOME to change this location."
echo ""
echo "Usage:"
echo "  /codebase-audit              Full audit"
echo "  /codebase-audit --quick      2-minute smoke check"
echo "  /codebase-audit --suggest-fixes  Audit with inline fix diffs"
