{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "version": "2.15.0"
        }
      },
      "results": [
        {
          "ruleId": "js/sql-injection",
          "level": "error",
          "message": { "text": "SQL injection via user input." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/api/users.ts" },
                "region": { "startLine": 42 }
              }
            }
          ],
          "properties": { "tags": ["security"] }
        },
        {
          "ruleId": "js/xss",
          "level": "error",
          "message": { "text": "Unescaped user input rendered to HTML." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/ui/templates.ts" },
                "region": { "startLine": 78 }
              }
            }
          ],
          "properties": { "tags": ["security"] }
        },
        {
          "ruleId": "js/weak-crypto",
          "level": "warning",
          "message": { "text": "MD5 is cryptographically broken." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/lib/crypto.ts" },
                "region": { "startLine": 18 }
              }
            }
          ],
          "properties": { "tags": ["security"] }
        }
      ]
    },
    {
      "tool": {
        "driver": {
          "name": "Semgrep",
          "version": "1.50.0"
        }
      },
      "results": [
        {
          "ruleId": "python.lang.security.audit.dangerous-subprocess",
          "level": "error",
          "message": { "text": "subprocess called with shell=True and user input." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "scripts/runner.py" },
                "region": { "startLine": 22 }
              }
            }
          ],
          "properties": { "tags": ["security"] }
        },
        {
          "ruleId": "generic.secrets.gitleaks.aws-access-key",
          "level": "error",
          "message": { "text": "Possible AWS access key committed." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "config/dev.env" },
                "region": { "startLine": 5 }
              }
            }
          ],
          "properties": { "tags": ["secrets"] }
        },
        {
          "ruleId": "javascript.lang.best-practice.no-dynamic-exec",
          "level": "warning",
          "message": { "text": "Avoid dynamic code execution functions." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/lib/parser.ts" },
                "region": { "startLine": 91 }
              }
            }
          ],
          "properties": { "tags": ["quality"] }
        }
      ]
    }
  ]
}
