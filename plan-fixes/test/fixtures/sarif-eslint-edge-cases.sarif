{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "ESLint",
          "version": "8.57.0",
          "informationUri": "https://eslint.org/"
        }
      },
      "results": [
        {
          "ruleId": "no-unused-vars",
          "level": "warning",
          "message": { "text": "'foo' is defined but never used." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "/home/runner/work/myrepo/myrepo/src/lib/helpers.ts" },
                "region": { "startLine": 14 }
              }
            }
          ]
        },
        {
          "ruleId": "no-console",
          "level": "warning",
          "message": { "text": "Unexpected console statement." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/api/debug.ts" }
              }
            }
          ],
          "fixes": [
            {
              "description": { "text": "Remove the console statement." }
            }
          ]
        },
        {
          "ruleId": "prefer-const",
          "level": "warning",
          "message": { "text": "'x' is never reassigned. Use 'const' instead." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/lib/util.ts" },
                "region": { "startLine": 55 }
              }
            }
          ]
        }
      ]
    }
  ]
}
